---
interface Props {
  author?: string;
}
const { author } = Astro.props;
---

<blockquote class="fancy-quote">
  <p class="fq-content"><slot /></p>
  {author && <footer class="fq-author">— {author}</footer>}
</blockquote>

<style>
  .fancy-quote {
    margin: 2rem 0;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--muted-bg);
    font-style: italic;
  }
  .fq-content {
    margin: 0;
    font-size: 1.05em;
    line-height: 1.6;
    color: var(--ink);
  }
  .fq-author {
    margin-top: 0.5rem;
    text-align: right;
    font-style: normal;
    color: var(--muted);
    font-size: 0.9em;
  }
</style>
