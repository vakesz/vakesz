---
import { SITE } from "../consts";
import SocialIcons from "./SocialIcons.astro";
const year = new Date().getFullYear();
---

<footer class="site-footer" transition:persist="site-footer">
  <div class="wrap">
    <p class="copy">© {year} {SITE.author}</p>
    <div class="links" aria-label="Footer links">
      <SocialIcons variant="inline" />
      <a class="rss" href="/rss.xml" aria-label="RSS feed" title="RSS feed">
        <svg
          viewBox="0 0 24 24"
          width="18"
          height="18"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M4 11a9 9 0 0 1 9 9"></path>
          <path d="M4 4a16 16 0 0 1 16 16"></path>
          <circle cx="5" cy="19" r="1.5"></circle>
        </svg>
      </a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    margin-top: 4rem;
    padding: 1.5rem 0;
    color: var(--muted);
    font-size: 0.88rem;
  }
  .wrap {
    max-width: var(--content-wide);
    margin: 0 auto;
    padding: 0 1.25rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
    align-items: center;
    justify-content: space-between;
    line-height: 1;
  }
  .copy {
    margin: 0;
    line-height: 1;
  }
  .links {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    line-height: 1;
  }
  .rss {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--muted);
    line-height: 1;
    transition: color 150ms;
  }
  .rss:hover {
    color: var(--accent);
  }
  @media (max-width: 480px) {
    .site-footer {
      margin-top: 3rem;
      padding: 1.25rem 0;
    }
    .wrap {
      flex-direction: column;
      gap: 0.85rem;
      font-size: 0.84rem;
    }
  }
</style>
