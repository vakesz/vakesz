---
import { SITE, NAV } from "../consts";
import ThemeToggle from "./ThemeToggle.astro";

const path = Astro.url.pathname;
function isActive(href: string) {
  if (href === "/") return path === "/";
  return path === href || path.startsWith(href);
}
---

<header class="site-header">
  <div class="wrap">
    <a class="brand" href="/">
      <span class="brand-name">vakesz.com</span>
    </a>
    <nav aria-label="Primary">
      <ul>
        {
          NAV.map((item) => (
            <li>
              <a href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <a class="cta" href={`mailto:${SITE.email}`}>Get in touch</a>
    <ThemeToggle />
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--border);
    background: color-mix(in oklab, var(--bg) 85%, transparent);
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: saturate(1.4) blur(10px);
    -webkit-backdrop-filter: saturate(1.4) blur(10px);
  }
  .wrap {
    max-width: var(--content-wide);
    margin: 0 auto;
    padding: 0.85rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: -0.01em;
  }
  nav {
    margin-left: auto;
  }
  nav ul {
    display: flex;
    gap: 1.2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  nav a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.95rem;
    padding: 0.25rem 0;
    border-bottom: 1px solid transparent;
    transition:
      color 150ms,
      border-color 150ms;
  }
  nav a:hover {
    color: var(--ink);
  }
  nav a[aria-current="page"] {
    color: var(--ink);
    border-bottom-color: var(--accent);
  }
  .cta {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.95rem;
    border-radius: 999px;
    font-size: 0.88rem;
    font-weight: 500;
    color: #fff;
    background-image: linear-gradient(135deg, var(--accent), var(--accent-2, #8b5cf6));
    border: 1px solid transparent;
    text-decoration: none;
    transition:
      transform 150ms,
      box-shadow 150ms,
      filter 150ms;
    box-shadow: 0 6px 20px -8px color-mix(in oklab, var(--accent) 70%, transparent);
  }
  .cta:hover {
    transform: translateY(-1px);
    filter: brightness(1.05);
    box-shadow: 0 10px 28px -8px color-mix(in oklab, var(--accent) 70%, transparent);
  }
  @media (max-width: 720px) {
    .cta {
      display: none;
    }
  }
  @media (max-width: 540px) {
    nav ul {
      gap: 0.85rem;
    }
    nav a {
      font-size: 0.9rem;
    }
  }
</style>
