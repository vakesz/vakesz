---
import { SITE, NAV } from "../consts";
import { isActiveNav } from "../lib/nav";
import ThemeToggle from "./ThemeToggle.astro";

const path = Astro.url.pathname;
---

<header class="site-header" transition:persist="site-header">
  <div class="wrap">
    <a class="brand" href="/">
      <img class="brand-mark" src="/apple-touch-icon.png" alt="" width="28" height="28" />
      <span class="brand-text">
        <span class="brand-name">vakesz.com</span>
        <span class="brand-tag">{SITE.jobTitle}</span>
      </span>
    </a>

    <nav class="nav-desktop" aria-label="Primary">
      <ul>
        {
          NAV.map((item) => (
            <li>
              <a href={item.href} aria-current={isActiveNav(item.href, path) ? "page" : undefined}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="header-actions">
      <a class="cta" href={`mailto:${SITE.email}`}>Get in touch</a>
      <ThemeToggle />
      <button
        type="button"
        class="menu-toggle"
        id="menu-toggle"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="primary-nav"
      >
        <span class="bar" aria-hidden="true"></span>
        <span class="bar" aria-hidden="true"></span>
        <span class="bar" aria-hidden="true"></span>
      </button>
    </div>
  </div>
</header>

<nav
  id="primary-nav"
  class="nav-drawer"
  aria-label="Mobile"
  data-open="false"
  transition:persist="primary-nav"
>
  <ul>
    {
      NAV.map((item) => (
        <li>
          <a href={item.href} aria-current={isActiveNav(item.href, path) ? "page" : undefined}>
            {item.label}
          </a>
        </li>
      ))
    }
    <li class="drawer-cta">
      <a href={`mailto:${SITE.email}`}>Get in touch →</a>
    </li>
  </ul>
</nav>
<div class="nav-scrim" data-open="false" aria-hidden="true" transition:persist="nav-scrim"></div>

<script>
  import "../scripts/nav";
</script>

<style>
  .site-header {
    border-bottom: 1px solid var(--border);
    background: color-mix(in oklab, var(--bg) 86%, transparent);
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: saturate(1.4) blur(10px);
    -webkit-backdrop-filter: saturate(1.4) blur(10px);
  }
  .wrap {
    max-width: var(--content-wide);
    margin: 0 auto;
    padding: 0.85rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-weight: 600;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: -0.01em;
    min-width: 0;
  }
  .brand-mark {
    flex: none;
    width: 28px;
    height: 28px;
    border-radius: 6px;
    display: block;
  }
  .brand-text {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    line-height: 1;
    min-width: 0;
  }
  .brand-name {
    font-size: 1rem;
    line-height: 1.1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .brand-tag {
    margin-top: 2px;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    line-height: 1.1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }
  .nav-desktop {
    margin-left: auto;
  }
  .nav-desktop ul {
    display: flex;
    gap: 1.4rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav-desktop a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.95rem;
    padding: 0.25rem 0;
    border-bottom: 1px solid transparent;
    transition:
      color 150ms,
      border-color 150ms;
  }
  .nav-desktop a:hover {
    color: var(--ink);
  }
  .nav-desktop a[aria-current="page"] {
    color: var(--ink);
    border-bottom-color: var(--accent);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .cta {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.95rem;
    border-radius: 999px;
    font-size: 0.88rem;
    font-weight: 500;
    color: #fff;
    background-image: var(--gradient-brand);
    border: 1px solid transparent;
    text-decoration: none;
    transition:
      transform 150ms,
      box-shadow 150ms,
      filter 150ms;
    box-shadow: 0 6px 20px -8px color-mix(in oklab, var(--accent) 70%, transparent);
  }
  .cta:hover {
    transform: translateY(-1px);
    filter: brightness(1.05);
    box-shadow: 0 10px 28px -8px color-mix(in oklab, var(--accent) 70%, transparent);
  }

  /* Hamburger button */
  .menu-toggle {
    display: none;
    width: 40px;
    height: 40px;
    padding: 0;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--ink);
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 4px;
    cursor: pointer;
    transition:
      border-color 150ms,
      background 150ms;
  }
  .menu-toggle:hover {
    border-color: var(--accent);
  }
  .menu-toggle .bar {
    display: block;
    width: 18px;
    height: 2px;
    background: currentColor;
    border-radius: 2px;
    transition:
      transform 200ms ease,
      opacity 150ms ease;
  }
  .menu-toggle[aria-expanded="true"] .bar:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  .menu-toggle[aria-expanded="true"] .bar:nth-child(2) {
    opacity: 0;
  }
  .menu-toggle[aria-expanded="true"] .bar:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* Drawer (rendered outside the header to avoid the backdrop-filter
     containing-block trap) */
  .nav-drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(320px, 84vw);
    background: var(--bg);
    border-left: 1px solid var(--border);
    box-shadow: -20px 0 60px -20px color-mix(in oklab, var(--accent) 35%, transparent);
    padding: 4.5rem 1.5rem 2rem;
    transform: translateX(100%);
    transition: transform 240ms ease;
    visibility: hidden;
    z-index: 30;
    overflow-y: auto;
    display: none;
  }
  .nav-drawer[data-open="true"] {
    transform: translateX(0);
    visibility: visible;
  }
  .nav-drawer ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }
  .nav-drawer li + li {
    border-top: 1px solid var(--border);
  }
  .nav-drawer a {
    display: block;
    font-size: 1.1rem;
    padding: 0.95rem 0.25rem;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: -0.01em;
  }
  .nav-drawer a[aria-current="page"] {
    color: var(--accent);
  }
  .nav-drawer .drawer-cta a {
    color: var(--accent);
  }

  .nav-scrim {
    display: none;
    position: fixed;
    inset: 0;
    background: color-mix(in oklab, var(--ink) 35%, transparent);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    z-index: 28;
    opacity: 0;
    pointer-events: none;
    transition: opacity 200ms ease;
  }
  .nav-scrim[data-open="true"] {
    opacity: 1;
    pointer-events: auto;
  }

  @media (max-width: 720px) {
    .nav-desktop {
      display: none;
    }
    .cta {
      display: none;
    }
    .menu-toggle {
      display: inline-flex;
    }
    .nav-drawer {
      display: block;
    }
    .nav-scrim {
      display: block;
    }
    .header-actions {
      margin-left: auto;
    }
    :global(html[data-nav-open]) {
      overflow: hidden;
    }
  }

  @media (max-width: 420px) {
    .wrap {
      padding: 0.7rem 1rem;
      gap: 0.5rem;
    }
    .header-actions {
      gap: 0.35rem;
    }
    .brand-name {
      font-size: 0.95rem;
    }
  }
</style>
