---
type NoticeType = "note" | "info" | "warning" | "error";
interface Props {
  type?: NoticeType;
  title?: string;
}
const { type = "note", title } = Astro.props;
const role = type === "warning" || type === "error" ? "alert" : "note";
---

<aside class:list={["notice", `notice-${type}`]} role={role}>
  {title && <strong class="notice-title">{title}</strong>}
  <div class="notice-content"><slot /></div>
</aside>

<style>
  .notice {
    border-left: 3px solid var(--accent);
    background: var(--muted-bg);
    padding: 0.85rem 1.1rem;
    border-radius: 6px;
    margin: 1.5rem 0;
    font-size: 0.96em;
  }
  .notice-title {
    display: block;
    margin-bottom: 0.35rem;
    color: var(--ink);
  }
  .notice-content :global(p:last-child) {
    margin-bottom: 0;
  }
  .notice-note {
    border-color: var(--muted);
  }
  .notice-info {
    border-color: var(--accent);
  }
  .notice-warning {
    border-color: #d97706;
    background: color-mix(in oklab, #d97706 10%, transparent);
  }
  .notice-error {
    border-color: #dc2626;
    background: color-mix(in oklab, #dc2626 10%, transparent);
  }
</style>
