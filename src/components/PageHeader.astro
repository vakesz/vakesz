---
interface Props {
  eyebrow?: string;
  title: string;
  accented?: string;
  lede?: string;
  align?: "left" | "center";
}
const { eyebrow, title, accented, lede, align = "left" } = Astro.props;
---

<header class:list={["page-hero", align]}>
  <div class="glow" aria-hidden="true"></div>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h1>
    {
      accented ? (
        <>
          {title} <span class="gradient">{accented}</span>
        </>
      ) : (
        <span class="gradient">{title}</span>
      )
    }
  </h1>
  {
    lede && (
      <p class="lede">
        <slot name="lede">{lede}</slot>
      </p>
    )
  }
  <slot />
</header>
