---
import type { CollectionEntry } from "astro:content";
import FormattedDate from "./FormattedDate.astro";

interface Props {
  post: CollectionEntry<"posts">;
}
const { post } = Astro.props;
const href = `/posts/${post.id}/`;
const titleId = `post-${post.id}-title`;
const tags = post.data.tags.slice(0, 3);
---

<a class="card post-card" href={href} aria-labelledby={titleId}>
  <h3 class="title" id={titleId}>{post.data.title}</h3>
  <p class="desc">{post.data.description}</p>
  <div class="meta">
    <FormattedDate date={post.data.pubDate} short />
    {
      tags.length > 0 && (
        <>
          <span class="dot" aria-hidden="true">
            ·
          </span>
          <span class="tags">
            {tags.map((t) => (
              <span class="tag">#{t}</span>
            ))}
          </span>
        </>
      )
    }
  </div>
</a>

<style>
  .post-card .title,
  .post-card .desc {
    overflow-wrap: anywhere;
  }
  .meta {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
    font-size: 0.82rem;
    color: var(--muted);
    font-family: var(--font-mono);
  }
  .tags {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.25rem 0.6rem;
    letter-spacing: 0.01em;
    min-width: 0;
  }
  .tag {
    white-space: nowrap;
  }
  @media (max-width: 640px) {
    .meta {
      font-size: 0.78rem;
      row-gap: 0.2rem;
    }
  }
</style>
