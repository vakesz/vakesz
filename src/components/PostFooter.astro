---
import type { CollectionEntry } from "astro:content";

interface Props {
  prev?: CollectionEntry<"posts">;
  next?: CollectionEntry<"posts">;
}

const { prev, next } = Astro.props;
---

{
  (prev || next) && (
    <nav class="post-nav" aria-label="More posts">
      {prev ? (
        <a class="post-nav-link prev" href={`/posts/${prev.id}/`} rel="prev">
          <span class="dir">← Previous</span>
          <span class="title">{prev.data.title}</span>
        </a>
      ) : (
        <span />
      )}
      {next ? (
        <a class="post-nav-link next" href={`/posts/${next.id}/`} rel="next">
          <span class="dir">Next →</span>
          <span class="title">{next.data.title}</span>
        </a>
      ) : (
        <span />
      )}
    </nav>
  )
}

<style>
  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin: 2.5rem 0 0;
  }
  .post-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 0.9rem 1rem;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--card-bg);
    color: inherit;
    text-decoration: none;
    transition:
      border-color 150ms,
      transform 150ms;
    min-width: 0;
  }
  .post-nav-link:hover,
  .post-nav-link:hover .title,
  .post-nav-link:hover .dir {
    text-decoration: none;
  }
  .post-nav-link:hover {
    border-color: var(--accent);
    transform: translateY(-1px);
  }
  .post-nav-link.next {
    text-align: right;
    align-items: flex-end;
  }
  .post-nav-link .dir {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--muted);
    letter-spacing: 0.02em;
  }
  .post-nav-link .title {
    font-weight: 600;
    font-size: 0.98rem;
    letter-spacing: -0.01em;
    line-height: 1.35;
    overflow-wrap: anywhere;
  }

  @media (max-width: 640px) {
    .post-nav {
      grid-template-columns: 1fr;
      gap: 0.6rem;
    }
    .post-nav-link.next {
      text-align: left;
      align-items: flex-start;
    }
  }
</style>
