---
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
}
const { project } = Astro.props;
const href = `/projects/${project.id}/`;
---

<a class="card project-card" href={href}>
  <div class="row">
    <h3 class="title">{project.data.title}</h3>
    {
      project.data.pinned && (
        <span class="pinned" aria-label="Pinned">
          ★
        </span>
      )
    }
  </div>
  <p class="desc">{project.data.description}</p>
  {
    project.data.stack.length > 0 && (
      <ul class="stack">
        {project.data.stack.slice(0, 5).map((s) => (
          <li>{s}</li>
        ))}
      </ul>
    )
  }
</a>

<style>
  .project-card {
    height: 100%;
  }
  .row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
  }
  .row .title {
    min-width: 0;
    overflow-wrap: anywhere;
  }
  .project-card .desc {
    overflow-wrap: anywhere;
  }
  .pinned {
    margin-left: auto;
    flex: none;
    color: var(--accent);
    font-size: 0.9rem;
  }
  .stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .stack li {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 0.15rem 0.5rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--muted);
  }
  @media (max-width: 640px) {
    .stack li {
      font-size: 0.69rem;
    }
  }
</style>
