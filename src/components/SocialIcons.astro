---
import { SITE, SOCIAL } from "../consts";

interface Props {
  variant?: "round" | "inline";
}
const { variant = "round" } = Astro.props;

type IconId = "github" | "x" | "linkedin" | "instagram" | "youtube" | "mail";

const icons: Record<IconId, { paths: string[]; fill?: boolean }> = {
  github: {
    paths: [
      "M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4",
      "M9 18c-4.51 2-5-2-7-2",
    ],
  },
  x: {
    fill: true,
    paths: [
      "M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.657l-5.214-6.817-5.967 6.817H1.68l7.73-8.835L1.253 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z",
    ],
  },
  linkedin: {
    paths: [
      "M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z",
      "M2 9h4v12H2z",
      "M4 4a2 2 0 1 1 0 4 2 2 0 0 1 0-4z",
    ],
  },
  instagram: {
    paths: [
      "M2 7a5 5 0 0 1 5-5h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5z",
      "M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z",
      "M17.5 6.5h.01",
    ],
  },
  youtube: {
    paths: [
      "M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17",
      "m10 15 5-3-5-3z",
    ],
  },
  mail: {
    paths: [
      "M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z",
      "m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7",
    ],
  },
};

const links: { name: string; href: string; id: IconId }[] = [
  { name: "GitHub", href: SOCIAL.github, id: "github" },
  { name: "X (Twitter)", href: SOCIAL.twitter, id: "x" },
  { name: "LinkedIn", href: SOCIAL.linkedin, id: "linkedin" },
  { name: "Instagram", href: SOCIAL.instagram, id: "instagram" },
  { name: "YouTube", href: SOCIAL.youtube, id: "youtube" },
  { name: "Email", href: `mailto:${SITE.email}`, id: "mail" },
];
---

<ul class:list={["social-icons", variant]} aria-label="Social links">
  {
    links.map((l) => {
      const icon = icons[l.id];
      return (
        <li>
          <a
            href={l.href}
            aria-label={l.name}
            title={l.name}
            rel={l.id === "mail" ? undefined : "me"}
          >
            <svg
              viewBox="0 0 24 24"
              width="18"
              height="18"
              fill={icon.fill ? "currentColor" : "none"}
              stroke={icon.fill ? "none" : "currentColor"}
              stroke-width={icon.fill ? undefined : "1.8"}
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              {icon.paths.map((d) => (
                <path d={d} />
              ))}
            </svg>
          </a>
        </li>
      );
    })
  }
</ul>

<style>
  .social-icons {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .social-icons a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 999px;
    border: 1px solid var(--border);
    color: var(--muted);
    background: var(--card-bg);
    text-decoration: none;
    transition:
      color 150ms,
      border-color 150ms,
      transform 150ms,
      box-shadow 150ms;
  }
  .social-icons a:hover {
    color: var(--accent);
    border-color: var(--accent);
    transform: translateY(-1px);
    box-shadow: 0 6px 18px -8px color-mix(in oklab, var(--accent) 60%, transparent);
  }
  .social-icons.inline a {
    width: auto;
    height: auto;
    padding: 0;
    border: 0;
    background: transparent;
  }
  .social-icons.inline a:hover {
    transform: none;
    box-shadow: none;
  }
</style>
