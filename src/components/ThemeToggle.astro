---

---

<button
  id="theme-toggle"
  type="button"
  aria-label="Toggle color theme"
  aria-pressed="false"
  title="Toggle theme"
>
  <svg
    class="icon sun"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path
      d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
    ></path>
  </svg>
  <svg
    class="icon moon"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<script>
  import "../scripts/theme";
</script>

<style>
  #theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    padding: 0;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: transparent;
    color: var(--ink);
    cursor: pointer;
    transition:
      border-color 150ms,
      background 150ms,
      color 150ms;
  }
  #theme-toggle:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  #theme-toggle .icon {
    display: none;
  }
  :global(html[data-theme="light"]) #theme-toggle .moon {
    display: block;
  }
  :global(html[data-theme="dark"]) #theme-toggle .sun {
    display: block;
  }
</style>
