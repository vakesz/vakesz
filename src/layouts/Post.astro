---
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";
import Base from "./Base.astro";
import FormattedDate from "../components/FormattedDate.astro";
import { tagSlug } from "../lib/content";

interface Props {
  title: string;
  description: string;
  slug: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  cover?: { src: ImageMetadata | string; alt: string; caption?: string };
  minutesRead?: number;
}

const {
  title,
  description,
  slug,
  pubDate,
  updatedDate,
  tags = [],
  cover,
  minutesRead,
} = Astro.props;

const coverOg = typeof cover?.src === "string" ? cover.src : cover?.src.src;
const ogImage = coverOg ?? `/og/${slug}.png`;
---

<Base
  title={title}
  description={description}
  image={ogImage}
  article
  pubDate={pubDate}
  updatedDate={updatedDate}
  tags={tags}
>
  <article class="prose post">
    <header class="post-header page-hero">
      <div class="glow" aria-hidden="true"></div>
      <p class="eyebrow">Post</p>
      <h1><span class="gradient">{title}</span></h1>
      <p class="post-meta">
        <FormattedDate date={pubDate} />
        {
          minutesRead && (
            <>
              <span class="dot" aria-hidden="true">
                ·
              </span>
              <span>{minutesRead} min read</span>
            </>
          )
        }
        {
          updatedDate && (
            <>
              <span class="dot" aria-hidden="true">
                ·
              </span>
              <span>
                updated <FormattedDate date={updatedDate} />
              </span>
            </>
          )
        }
      </p>
    </header>

    {
      cover && (
        <figure class="cover">
          {typeof cover.src === "string" ? (
            <img src={cover.src} alt={cover.alt} loading="eager" decoding="async" />
          ) : (
            <Picture
              src={cover.src}
              alt={cover.alt}
              widths={[640, 880, 1280, 1760]}
              sizes="(max-width: 880px) 100vw, 880px"
              loading="eager"
              decoding="async"
              fetchpriority="high"
              formats={["avif", "webp"]}
            />
          )}
          {cover.caption && <figcaption>{cover.caption}</figcaption>}
        </figure>
      )
    }

    <div class="post-body">
      <slot />
    </div>

    {
      tags.length > 0 && (
        <ul class="tag-list" aria-label="Tags">
          {tags.map((t) => (
            <li>
              <a href={`/tags/${tagSlug(t)}/`}>#{t}</a>
            </li>
          ))}
        </ul>
      )
    }

    <slot name="after" />
  </article>
</Base>

<style>
  .post-header {
    margin-bottom: 1.25rem;
  }
  .post-header h1 {
    margin-bottom: 0.5rem;
  }
  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--muted);
    margin: 0;
  }
  .cover {
    margin: 1.5rem -0.5rem 2rem;
  }
  .cover :global(img) {
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    border: 1px solid var(--border);
  }
  .cover figcaption {
    margin-top: 0.5rem;
    text-align: center;
    color: var(--muted);
    font-size: 0.86rem;
  }
  .post-body {
    font-size: 1.02rem;
  }
</style>
