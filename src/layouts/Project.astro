---
import Base from "./Base.astro";

interface Props {
  title: string;
  description: string;
  repo?: string;
  homepage?: string;
  stack?: string[];
  archived?: boolean;
}

const { title, description, repo, homepage, stack = [], archived } = Astro.props;
---

<Base title={title} description={description}>
  <article class="prose project">
    <header class="project-header page-hero">
      <div class="glow" aria-hidden="true"></div>
      <p class="eyebrow">Project</p>
      <h1>
        <span class="gradient">{title}</span>
        {
          archived && (
            <span
              class="archived"
              aria-label="Archived project"
              title="Archived — no longer maintained"
            >
              archived
            </span>
          )
        }
      </h1>
      <p class="lede">{description}</p>
      <div class="actions">
        {
          repo && (
            <a class="btn" href={repo}>
              Source ↗
            </a>
          )
        }
        {
          homepage && (
            <a class="btn btn-primary" href={homepage}>
              Live ↗
            </a>
          )
        }
      </div>
      {
        stack.length > 0 && (
          <ul class="stack-list" aria-label="Stack">
            {stack.map((s) => (
              <li>{s}</li>
            ))}
          </ul>
        )
      }
    </header>

    <div class="project-body">
      <slot />
    </div>
  </article>
</Base>

<style>
  .actions {
    display: flex;
    gap: 0.5rem;
    margin: 1.25rem 0 0.75rem;
    flex-wrap: wrap;
  }
  .stack-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    padding: 0;
    margin: 0.75rem 0 0;
  }
  .stack-list li {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    padding: 0.2rem 0.6rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--muted);
  }
  .archived {
    margin-left: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 0.15rem 0.5rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--muted);
    vertical-align: middle;
    font-weight: 400;
  }
</style>
