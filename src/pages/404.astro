---
import Base from "../layouts/Base.astro";
import PageHeader from "../components/PageHeader.astro";
---

<Base title="404 · Not Found" description="This page doesn't exist.">
  <section class="not-found">
    <p class="code gradient">404</p>
    <PageHeader align="center" title="Lost in " accented="transit.">
      <Fragment slot="lede">
        The page you're looking for doesn't exist - or it got renamed when I was tidying up. Head <a
          href="/">home</a
        >, browse <a href="/posts/">posts</a>, or check
        <a href="/projects/">projects</a>.
      </Fragment>
    </PageHeader>
  </section>
</Base>

<style>
  .not-found {
    padding: 3rem 0 2rem;
    text-align: center;
  }
  .code {
    font-family: var(--font-mono);
    font-size: clamp(3.5rem, 10vw, 5.5rem);
    letter-spacing: -0.04em;
    margin: 0;
    line-height: 1;
    font-weight: 700;
  }
</style>
