---
import { getEntry, render } from "astro:content";
import Base from "../layouts/Base.astro";
import PageHeader from "../components/PageHeader.astro";
import SocialIcons from "../components/SocialIcons.astro";

const entry = await getEntry("pages", "about");
if (!entry) throw new Error("Missing src/content/pages/about.mdx");
const { Content } = await render(entry);
const { title, titleAccent, eyebrow, description, lede } = entry.data;
---

<Base title={title.trim()} description={description}>
  <section class="about-intro">
    <div class="about-photo">
      <img src="/img/wexl.webp" alt="Wexl Trails, Austria" loading="eager" decoding="async" />
    </div>

    <PageHeader eyebrow={eyebrow} title={title} accented={titleAccent} lede={lede}>
      <div class="about-social">
        <SocialIcons />
      </div>
    </PageHeader>
  </section>

  <article class="prose">
    <Content />
  </article>
</Base>

<style>
  .about-intro {
    display: grid;
    grid-template-columns: minmax(220px, 340px) minmax(0, 1fr);
    gap: 2.5rem;
    align-items: start;
    margin: 0.5rem 0 2.5rem;
  }

  .about-intro :global(.page-hero) {
    margin: 0;
    padding-top: 0.25rem;
  }

  .about-photo {
    width: min(340px, 100%);
    aspect-ratio: 4 / 5;
  }

  .about-photo :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 18px;
    border: 1px solid var(--border);
    box-shadow:
      0 24px 50px -26px color-mix(in oklab, var(--accent) 34%, transparent),
      0 16px 34px -24px color-mix(in oklab, var(--accent-2) 34%, transparent);
  }

  .about-social {
    margin-top: 1.4rem;
  }

  @media (max-width: 760px) {
    .about-intro {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      margin-bottom: 2rem;
    }

    .about-photo {
      width: min(260px, 72vw);
    }
  }
</style>
