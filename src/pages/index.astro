---
import { getCollection } from "astro:content";
import { Picture } from "astro:assets";
import Base from "../layouts/Base.astro";
import PostCard from "../components/PostCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SocialIcons from "../components/SocialIcons.astro";
import { SITE } from "../consts";
import { isPublished, byPubDateDesc, byPinnedThenOrder } from "../lib/content";
import mePhoto from "../assets/me.jpg";

const recentPosts = (await getCollection("posts", isPublished)).sort(byPubDateDesc).slice(0, 4);

const featuredProjects = (await getCollection("projects", ({ data }) => !data.archived))
  .sort(byPinnedThenOrder)
  .slice(0, 4);
---

<Base title={SITE.title} description={SITE.description} wide>
  <section class="hero">
    <div class="hero-copy">
      <h1>Hello, I'm <span class="gradient">Gábor.</span></h1>
      <p class="lede">
        Software engineer at <strong>Sigma Technology</strong> in Budapest. Six years on automotive software
        before that. Off the clock: forests and trails over screens.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="/projects/">See my work →</a>
        <a class="btn" href="/posts/">Read the blog</a>
      </div>
      <SocialIcons />
    </div>

    <div class="hero-photo">
      <div class="glow" aria-hidden="true"></div>
      <Picture
        src={mePhoto}
        alt="Gábor Pinkova"
        widths={[260, 420, 840]}
        sizes="(max-width: 820px) 260px, 420px"
        loading="eager"
        decoding="async"
        fetchpriority="high"
        formats={["avif", "webp"]}
      />
    </div>
  </section>

  <div class="section-title">
    <h2>Latest <span class="accented">posts</span></h2>
    <a href="/posts/">View all →</a>
  </div>
  <div class="stack">
    {recentPosts.map((post) => <PostCard post={post} />)}
  </div>

  <div class="section-title">
    <h2>Selected <span class="accented">projects</span></h2>
    <a href="/projects/">View all →</a>
  </div>
  <div class="grid-2">
    {featuredProjects.map((project) => <ProjectCard project={project} />)}
  </div>
</Base>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 3rem;
    align-items: center;
    padding: 2rem 0 3.5rem;
    position: relative;
  }
  .hero::before {
    content: "";
    position: absolute;
    inset: -10% -5% -10% -5%;
    background:
      radial-gradient(
        40% 50% at 20% 30%,
        color-mix(in oklab, var(--accent) 18%, transparent),
        transparent 70%
      ),
      radial-gradient(
        35% 45% at 80% 70%,
        color-mix(in oklab, var(--accent-2) 18%, transparent),
        transparent 70%
      );
    filter: blur(40px);
    z-index: -1;
    opacity: 0.9;
    pointer-events: none;
  }

  .hero h1 {
    font-size: clamp(2.1rem, 5.5vw, 3.4rem);
    letter-spacing: -0.035em;
    line-height: 1.05;
    margin: 0 0 1.1rem;
    font-weight: 700;
  }

  .hero .lede {
    font-size: 1.08rem;
    line-height: 1.65;
    color: var(--muted);
    margin: 0 0 1.6rem;
    max-width: 52ch;
  }
  .hero .lede strong {
    color: var(--ink);
    font-weight: 600;
  }

  .hero-actions {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-bottom: 1.6rem;
  }

  .hero-photo {
    position: relative;
    justify-self: center;
    width: min(420px, 100%);
    aspect-ratio: 1 / 1;
  }
  .hero-photo img {
    position: relative;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 28px;
    border: 1px solid var(--border);
    box-shadow:
      0 30px 60px -20px color-mix(in oklab, var(--accent) 35%, transparent),
      0 20px 40px -20px color-mix(in oklab, var(--accent-2) 35%, transparent);
    z-index: 1;
  }
  .hero-photo .glow {
    position: absolute;
    inset: -10%;
    background:
      radial-gradient(
        50% 50% at 30% 35%,
        color-mix(in oklab, var(--accent) 55%, transparent),
        transparent 70%
      ),
      radial-gradient(
        45% 45% at 75% 70%,
        color-mix(in oklab, var(--accent-2) 55%, transparent),
        transparent 70%
      );
    filter: blur(45px);
    opacity: 0.55;
    z-index: 0;
  }

  @media (max-width: 820px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 1rem 0 2.5rem;
    }
    .hero-photo {
      order: -1;
      justify-self: start;
      width: min(280px, 62%);
    }
  }

  @media (max-width: 520px) {
    .hero {
      gap: 1.35rem;
      padding: 0.5rem 0 2rem;
    }
    .hero h1 {
      font-size: clamp(1.85rem, 10vw, 2.35rem);
      margin-bottom: 0.9rem;
    }
    .hero .lede {
      font-size: 1rem;
      line-height: 1.58;
      margin-bottom: 1.2rem;
    }
    .hero-actions {
      margin-bottom: 1.2rem;
    }
    .hero-photo {
      justify-self: center;
      width: min(220px, 72%);
    }
  }
</style>
