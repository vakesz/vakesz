---
import { getCollection, render } from "astro:content";
import Post from "../../layouts/Post.astro";
import YouTube from "../../components/YouTube.astro";
import PostFooter from "../../components/PostFooter.astro";
import { isPublished, siblingPosts } from "../../lib/content";

const mdxComponents = { YouTube };

export async function getStaticPaths() {
  const posts = await getCollection("posts", isPublished);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, posts },
  }));
}

const { post, posts } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(post);
const minutesRead = remarkPluginFrontmatter?.minutesRead as number | undefined;
const { prev, next } = siblingPosts(posts, post);
---

<Post
  title={post.data.title}
  description={post.data.description}
  slug={post.id}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  tags={post.data.tags}
  cover={post.data.cover}
  minutesRead={minutesRead}
>
  <Content components={mdxComponents} />
  <PostFooter prev={prev} next={next} slot="after" />
</Post>
