---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";
import PageHeader from "../../components/PageHeader.astro";
import { isPublished, byPubDateDesc } from "../../lib/content";

const posts = (await getCollection("posts", isPublished)).sort(byPubDateDesc);

const grouped = new Map<number, typeof posts>();
for (const p of posts) {
  const year = p.data.pubDate.getFullYear();
  if (!grouped.has(year)) grouped.set(year, [] as typeof posts);
  grouped.get(year)!.push(p);
}
const years = [...grouped.keys()].sort((a, b) => b - a);
---

<Base
  title="Posts"
  description="All posts on vakesz.com — backend, automotive, career, and the occasional side project."
>
  <PageHeader
    eyebrow="Writing"
    title="All "
    accented="posts."
    lede={`Everything I've written here, newest first. ${posts.length} total.`}
  />

  {
    years.map((year) => (
      <section class="year-block">
        <h2 class="year">{year}</h2>
        <div class="stack">
          {grouped.get(year)!.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      </section>
    ))
  }
</Base>

<style>
  .year-block {
    margin-top: 2rem;
  }
  .year {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 0.9rem;
  }
</style>
