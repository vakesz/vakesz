---
import Base from "../layouts/Base.astro";
import PageHeader from "../components/PageHeader.astro";
---

<Base title="Search" description="Full-text search across every post and project on vakesz.com.">
  <PageHeader
    eyebrow="Find"
    title="Search the "
    accented="site."
    lede="Type to search across all posts and projects. Runs entirely in your browser — nothing leaves the page."
  />

  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <div id="search" class="search-box"></div>

  <script is:inline>
    window.addEventListener("DOMContentLoaded", () => {
      const el = document.getElementById("search");
      if (!el) return;
      import("/pagefind/pagefind-ui.js")
        .then(({ PagefindUI }) => {
          new PagefindUI({
            element: "#search",
            showImages: false,
            excerptLength: 30,
            resetStyles: false,
          });
        })
        .catch(() => {
          el.innerHTML =
            '<p style="color:var(--muted)">Search index not built yet. Run <code>bun run build</code> to generate it.</p>';
        });
    });
  </script>
</Base>

<style>
  .search-box {
    --pagefind-ui-primary: var(--accent);
    --pagefind-ui-text: var(--ink);
    --pagefind-ui-background: var(--bg);
    --pagefind-ui-border: var(--border);
    --pagefind-ui-tag: var(--muted-bg);
    --pagefind-ui-border-radius: 10px;
    --pagefind-ui-image-border-radius: 8px;
    --pagefind-ui-image-box-ratio: 3 / 2;
    --pagefind-ui-font: var(--font-sans);
  }
</style>
