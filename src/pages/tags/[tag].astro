---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";
import PageHeader from "../../components/PageHeader.astro";
import { isPublished, byPubDateDesc, tagSlug } from "../../lib/content";

export async function getStaticPaths() {
  const posts = await getCollection("posts", isPublished);

  const byTag = new Map<string, typeof posts>();
  for (const p of posts) {
    for (const t of p.data.tags) {
      const slug = tagSlug(t);
      if (!byTag.has(slug)) byTag.set(slug, [] as typeof posts);
      byTag.get(slug)!.push(p);
    }
  }

  return [...byTag.entries()].map(([tag, entries]) => ({
    params: { tag },
    props: {
      tag,
      posts: entries.sort(byPubDateDesc),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<Base title={`#${tag}`} description={`Posts tagged #${tag} on vakesz.com.`}>
  <PageHeader eyebrow="Tag" title="#" accented={tag}>
    <Fragment slot="lede">
      {posts.length}
      {posts.length === 1 ? "post" : "posts"} tagged <code>{tag}</code>.
      <a href="/tags/">All tags →</a>
    </Fragment>
  </PageHeader>

  <div class="stack">
    {posts.map((post) => <PostCard post={post} />)}
  </div>
</Base>
