---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import PageHeader from "../../components/PageHeader.astro";
import { isPublished, tagSlug } from "../../lib/content";

const posts = await getCollection("posts", isPublished);

const counts = new Map<string, number>();
for (const p of posts) {
  for (const t of p.data.tags) {
    counts.set(t, (counts.get(t) ?? 0) + 1);
  }
}
const tags = [...counts.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
---

<Base title="Tags" description="All tags used across posts on vakesz.com.">
  <PageHeader
    eyebrow="Browse"
    title="All"
    accented="tags."
    lede={`${tags.length} tags across ${posts.length} posts.`}
  />

  <ul class="tag-cloud">
    {
      tags.map(([tag, count]) => (
        <li>
          <a href={`/tags/${tagSlug(tag)}/`}>
            <span>#{tag}</span>
            <span class="count">{count}</span>
          </a>
        </li>
      ))
    }
  </ul>
</Base>

<style>
  .tag-cloud {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tag-cloud a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.7rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    text-decoration: none;
  }
  .tag-cloud a:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .count {
    color: var(--muted);
    font-size: 0.78rem;
  }
</style>
